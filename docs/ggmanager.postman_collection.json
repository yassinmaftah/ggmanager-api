{
  "info": {
    "name": "GGManager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "REST API for managing esports tournaments, registrations, matches and brackets."
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"player\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["const res = pm.response.json();", "if (res.data && res.data.access_token) {", "  pm.collectionVariables.set('token', res.data.access_token);", "}"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Tournaments",
      "item": [
        {
          "name": "List Tournaments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tournaments",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Get Tournament",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tournaments/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Create Tournament",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tournaments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Championship\",\n  \"game\": \"League of Legends\",\n  \"date\": \"2025-08-01T18:00:00\",\n  \"max_participants\": 16\n}"
            }
          }
        },
        {
          "name": "Update Tournament",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/tournaments/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Championship\",\n  \"max_participants\": 32\n}"
            }
          }
        },
        {
          "name": "Delete Tournament",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tournaments/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Join Tournament",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tournaments/1/join",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Close Tournament",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tournaments/1/close",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Get Bracket",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tournaments/1/bracket",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "Create Match",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/matches",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tournament_id\": 1,\n  \"round_number\": 1,\n  \"match_position\": 1,\n  \"player1_id\": 1,\n  \"player2_id\": 2,\n  \"next_match_id\": null\n}"
            }
          }
        },
        {
          "name": "Submit Score",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/matches/1/score",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"player1_score\": 3,\n  \"player2_score\": 1,\n  \"winner_id\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}
